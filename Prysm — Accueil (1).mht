@charset "utf-8";

*, ::before, ::after { box-sizing: border-box; margin: 0px; padding: 0px; }

:root { --cream: #f4f0e6; --dark: #1a1a14; --green: #2e5c3a; --green-light: #4a8c5c; --green-pale: #e8f0ea; --gold: #c8a84b; --gold-light: #f0dfa0; --text: #2c2c24; --muted: #6a6a58; }

html { scroll-behavior: smooth; }

body { background: var(--cream); color: var(--text); font-family: "DM Sans", sans-serif; overflow-x: hidden; }

body::after { content: ""; position: fixed; inset: 0px; background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 300 300' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.035'/%3E%3C/svg%3E"); pointer-events: none; z-index: 9999; opacity: 0.6; }

nav { position: fixed; top: 0px; left: 0px; right: 0px; z-index: 1000; display: flex; align-items: center; justify-content: space-between; padding: 0px 4rem; height: 80px; background: rgba(244, 240, 230, 0.92); backdrop-filter: blur(12px); border-bottom: 1px solid rgba(46, 92, 58, 0.12); transition: box-shadow 0.3s; }

nav.scrolled { box-shadow: rgba(26, 26, 20, 0.08) 0px 4px 32px; }

.nav-logo { display: flex; flex-direction: column; gap: 0.1rem; text-decoration: none; }

.nav-logo-main { font-family: "Playfair Display", serif; font-size: 1.6rem; font-weight: 900; letter-spacing: 0.12em; text-transform: uppercase; color: var(--green); line-height: 1; }

.nav-logo-sub { font-size: 0.6rem; letter-spacing: 0.38em; text-transform: uppercase; color: var(--gold); font-weight: 500; }

.nav-links { display: flex; align-items: center; gap: 0.5rem; list-style: none; }

.nav-links li a { text-decoration: none; font-size: 0.78rem; letter-spacing: 0.18em; text-transform: uppercase; font-weight: 500; color: var(--text); padding: 0.5rem 1.1rem; border-radius: 2px; transition: color 0.2s, background 0.2s; position: relative; }

.nav-links li a::after { content: ""; position: absolute; bottom: 0px; left: 1.1rem; right: 1.1rem; height: 1px; background: var(--green); transform: scaleX(0); transform-origin: left center; transition: transform 0.3s; }

.nav-links li a:hover { color: var(--green); }

.nav-links li a:hover::after { transform: scaleX(1); }

.nav-links li a.active { color: var(--green); }

.nav-links li a.active::after { transform: scaleX(1); }

.nav-cta { background: var(--green); border-radius: 2px; color: var(--cream) !important; padding: 0.6rem 1.5rem !important; }

.nav-cta::after { display: none !important; }

.nav-cta:hover { background: var(--green-light) !important; color: var(--cream) !important; }

.burger { display: none; flex-direction: column; gap: 5px; cursor: pointer; padding: 0.5rem; }

.burger span { display: block; width: 24px; height: 2px; background: var(--green); transition: 0.3s; }

#accueil { display: grid; grid-template-columns: 1fr 1fr; min-height: 100vh; padding-top: 80px; }

.hero-left { padding: 8rem 4rem 6rem; display: flex; flex-direction: column; justify-content: center; gap: 2rem; position: relative; }

.hero-eyebrow { display: flex; align-items: center; gap: 1rem; font-size: 0.7rem; letter-spacing: 0.42em; text-transform: uppercase; color: var(--gold); opacity: 0; animation: 0.8s ease 0.2s 1 normal forwards running fadeUp; }

.hero-eyebrow::before { content: ""; display: block; width: 32px; height: 1px; background: var(--gold); }

.hero-title { font-family: "Playfair Display", serif; font-size: clamp(3rem, 4.5vw, 5rem); font-weight: 900; line-height: 1.02; color: var(--dark); opacity: 0; animation: 0.9s ease 0.4s 1 normal forwards running fadeUp; }

.hero-title em { font-style: italic; color: var(--green); }

.hero-title .line-gold { color: var(--gold); font-style: normal; }

.hero-desc { font-size: 1rem; line-height: 1.85; color: var(--muted); font-weight: 300; max-width: 46ch; opacity: 0; animation: 0.9s ease 0.6s 1 normal forwards running fadeUp; }

.hero-bullets { list-style: none; display: flex; flex-direction: column; gap: 0.7rem; opacity: 0; animation: 0.9s ease 0.75s 1 normal forwards running fadeUp; }

.hero-bullets li { display: flex; align-items: center; gap: 0.85rem; font-size: 0.88rem; color: var(--text); font-weight: 400; }

.hero-bullets li::before { content: ""; display: block; width: 6px; height: 6px; background: var(--gold); border-radius: 50%; flex-shrink: 0; }

.hero-actions { display: flex; align-items: center; gap: 1.2rem; opacity: 0; animation: 0.9s ease 0.9s 1 normal forwards running fadeUp; }

.btn-primary { background: var(--green); color: var(--cream); padding: 0.9rem 2.4rem; font-size: 0.78rem; letter-spacing: 0.18em; text-transform: uppercase; border: none; cursor: pointer; font-family: "DM Sans", sans-serif; font-weight: 500; transition: background 0.25s, transform 0.2s; text-decoration: none; display: inline-block; }

.btn-primary:hover { background: var(--green-light); transform: translateY(-2px); }

.btn-outline { border: 1px solid var(--green); color: var(--green); padding: 0.9rem 2.4rem; font-size: 0.78rem; letter-spacing: 0.18em; text-transform: uppercase; background: transparent; cursor: pointer; font-family: "DM Sans", sans-serif; font-weight: 500; transition: background 0.25s, color 0.25s; text-decoration: none; display: inline-block; }

.btn-outline:hover { background: var(--green); color: var(--cream); }

.hero-right { background: var(--green); position: relative; overflow: hidden; display: flex; align-items: center; justify-content: center; }

.ring { position: absolute; border-radius: 50%; border: 1px solid rgba(255, 255, 255, 0.07); animation: 4s ease-in-out 0s infinite normal none running pulse; }

.ring-1 { width: 600px; height: 600px; top: -150px; right: -150px; animation-delay: 0s; }

.ring-2 { width: 400px; height: 400px; bottom: -80px; left: -80px; animation-delay: 1.2s; }

.ring-3 { width: 260px; height: 260px; top: 50%; left: 50%; transform: translate(-50%, -50%); border-color: rgba(200, 168, 75, 0.2); animation-delay: 2.4s; }

@keyframes pulse { 
  0%, 100% { transform: scale(1); opacity: 0.7; }
  50% { transform: scale(1.04); opacity: 1; }
}

.ring-3 { animation: 4s ease-in-out 2.4s infinite normal none running pulse3; }

@keyframes pulse3 { 
  0%, 100% { transform: translate(-50%, -50%) scale(1); }
  50% { transform: translate(-50%, -50%) scale(1.06); }
}

.hero-visual { position: relative; z-index: 2; text-align: center; padding: 3rem; }

.cycle-wrap { position: relative; width: 220px; height: 220px; margin: 0px auto 2rem; }

.cycle-outer { animation: 20s linear 0s infinite normal none running rotateCW; transform-origin: center center; }

.cycle-inner { animation: 14s linear 0s infinite normal none running rotateCCW; transform-origin: center center; }

@keyframes rotateCW { 
  100% { transform: rotate(360deg); }
}

@keyframes rotateCCW { 
  100% { transform: rotate(-360deg); }
}

.hero-visual-title { font-family: "Playfair Display", serif; font-size: 1.4rem; font-weight: 700; color: var(--cream); margin-bottom: 0.5rem; }

.hero-visual-sub { font-size: 0.72rem; letter-spacing: 0.35em; text-transform: uppercase; color: rgba(200, 168, 75, 0.8); }

.stat-float { position: absolute; background: rgba(244, 240, 230, 0.1); backdrop-filter: blur(8px); border: 1px solid rgba(244, 240, 230, 0.15); padding: 0.9rem 1.4rem; border-radius: 4px; }

.stat-float-1 { top: 18%; left: 8%; animation: 5s ease-in-out 0s infinite normal none running floatA; }

.stat-float-2 { bottom: 22%; right: 6%; animation: 6s ease-in-out 1s infinite normal none running floatB; }

@keyframes floatA { 
  0%, 100% { transform: translateY(0px); }
  50% { transform: translateY(-10px); }
}

@keyframes floatB { 
  0%, 100% { transform: translateY(0px); }
  50% { transform: translateY(-8px); }
}

.stat-float-num { font-family: "Playfair Display", serif; font-size: 1.6rem; font-weight: 900; color: var(--gold); }

.stat-float-label { font-size: 0.62rem; letter-spacing: 0.2em; text-transform: uppercase; color: rgba(244, 240, 230, 0.6); }

.stats-bar { background: var(--dark); display: grid; grid-template-columns: repeat(4, 1fr); border-top: 1px solid rgba(200, 168, 75, 0.2); }

.stat-item { padding: 3.5rem 2.5rem; border-right: 1px solid rgba(244, 240, 230, 0.07); text-align: center; transition: background 0.3s; }

.stat-item:last-child { border-right: none; }

.stat-item:hover { background: rgba(46, 92, 58, 0.3); }

.stat-num { font-family: "Playfair Display", serif; font-size: 3.2rem; font-weight: 900; color: var(--gold); line-height: 1; margin-bottom: 0.4rem; }

.stat-label { font-size: 0.72rem; letter-spacing: 0.3em; text-transform: uppercase; color: rgba(244, 240, 230, 0.45); }

.section-header { text-align: center; padding: 5rem 4rem 3rem; }

.section-eyebrow { font-size: 0.68rem; letter-spacing: 0.5em; text-transform: uppercase; color: var(--gold); display: flex; align-items: center; justify-content: center; gap: 1rem; margin-bottom: 1.2rem; }

.section-eyebrow::before, .section-eyebrow::after { content: ""; display: block; width: 40px; height: 1px; background: var(--gold); }

.section-title { font-family: "Playfair Display", serif; font-size: clamp(2rem, 3.5vw, 3rem); font-weight: 900; color: var(--dark); line-height: 1.1; }

.section-title em { color: var(--green); font-style: italic; }

.section-sub { font-size: 0.95rem; color: var(--muted); max-width: 52ch; margin: 1rem auto 0px; line-height: 1.8; font-weight: 300; }

#services { padding-bottom: 6rem; }

.services-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0px; border: 1px solid rgba(46, 92, 58, 0.12); margin: 0px 4rem; }

.service-card { padding: 3.5rem 2.8rem; border-right: 1px solid rgba(46, 92, 58, 0.1); position: relative; overflow: hidden; cursor: pointer; transition: background 0.35s; }

.service-card:last-child { border-right: none; }

.service-card::before { content: ""; position: absolute; bottom: 0px; left: 0px; right: 0px; height: 3px; background: var(--green); transform: scaleX(0); transform-origin: left center; transition: transform 0.4s; }

.service-card:hover { background: var(--green-pale); }

.service-card:hover::before { transform: scaleX(1); }

.service-num { font-family: "Playfair Display", serif; font-size: 4rem; font-weight: 900; color: rgba(46, 92, 58, 0.08); line-height: 1; margin-bottom: 1.2rem; transition: color 0.3s; }

.service-card:hover .service-num { color: rgba(46, 92, 58, 0.18); }

.service-title { font-family: "Playfair Display", serif; font-size: 1.25rem; font-weight: 700; color: var(--dark); margin-bottom: 0.8rem; }

.service-text { font-size: 0.88rem; line-height: 1.78; color: var(--muted); font-weight: 300; margin-bottom: 1.5rem; }

.service-bullets { list-style: none; display: flex; flex-direction: column; gap: 0.5rem; margin-bottom: 1.5rem; }

.service-bullets li { font-size: 0.82rem; color: var(--text); display: flex; align-items: flex-start; gap: 0.7rem; line-height: 1.5; }

.service-bullets li::before { content: ""; display: block; width: 5px; height: 5px; background: var(--gold); border-radius: 50%; flex-shrink: 0; margin-top: 0.42rem; }

.service-link { font-size: 0.75rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--green); text-decoration: none; font-weight: 500; display: flex; align-items: center; gap: 0.5rem; transition: gap 0.25s; }

.service-link:hover { gap: 0.9rem; }

.revaloris-strip { display: grid; grid-template-columns: 1fr 1fr; background: var(--dark); }

.rev-content { padding: 7rem 5rem; display: flex; flex-direction: column; justify-content: center; gap: 1.8rem; }

.rev-badge { display: inline-block; font-size: 0.62rem; letter-spacing: 0.45em; text-transform: uppercase; color: var(--gold); border: 1px solid rgba(200, 168, 75, 0.4); padding: 0.35rem 1rem; width: fit-content; }

.rev-title { font-family: "Playfair Display", serif; font-size: clamp(2.4rem, 3.5vw, 3.8rem); font-weight: 900; color: var(--cream); line-height: 1.05; }

.rev-title span { color: var(--gold); }

.rev-tagline { font-size: 0.72rem; letter-spacing: 0.35em; text-transform: uppercase; color: rgba(244, 240, 230, 0.35); }

.rev-desc { font-size: 0.95rem; line-height: 1.9; color: rgba(244, 240, 230, 0.65); font-weight: 300; max-width: 48ch; }

.rev-bullets { list-style: none; display: flex; flex-direction: column; gap: 0.8rem; }

.rev-bullets li { font-size: 0.88rem; color: rgba(244, 240, 230, 0.75); display: flex; align-items: flex-start; gap: 0.85rem; line-height: 1.6; }

.rev-bullets li::before { content: ""; display: block; width: 6px; height: 6px; background: var(--gold); border-radius: 50%; flex-shrink: 0; margin-top: 0.4rem; }

.btn-gold { background: var(--gold); color: var(--dark); padding: 0.9rem 2.4rem; font-size: 0.78rem; letter-spacing: 0.18em; text-transform: uppercase; border: none; cursor: pointer; font-family: "DM Sans", sans-serif; font-weight: 600; width: fit-content; text-decoration: none; display: inline-block; transition: background 0.25s, transform 0.2s; }

.btn-gold:hover { background: var(--gold-light); transform: translateY(-2px); }

.rev-visual { background: var(--green); position: relative; overflow: hidden; display: flex; align-items: center; justify-content: center; min-height: 500px; }

.rev-visual::before { content: ""; position: absolute; width: 500px; height: 500px; border: 80px solid rgba(255, 255, 255, 0.05); border-radius: 50%; top: -120px; right: -120px; }

.rev-visual::after { content: ""; position: absolute; width: 300px; height: 300px; border: 50px solid rgba(200, 168, 75, 0.1); border-radius: 50%; bottom: -50px; left: -50px; }

.rev-visual-inner { position: relative; z-index: 2; text-align: center; padding: 3rem; }

.rev-big-text { font-family: "Playfair Display", serif; font-size: 5rem; font-weight: 900; color: rgba(244, 240, 230, 0.1); line-height: 1; letter-spacing: -0.02em; }

.rev-center-stat { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); text-align: center; }

.rev-center-num { font-family: "Playfair Display", serif; font-size: 4rem; font-weight: 900; color: var(--gold); }

.rev-center-label { font-size: 0.68rem; letter-spacing: 0.3em; text-transform: uppercase; color: rgba(244, 240, 230, 0.5); }

#clients { padding: 6rem 0px; }

.clients-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; padding: 2rem 4rem 0px; }

.client-card { border: 1px solid rgba(46, 92, 58, 0.12); padding: 2.8rem 2.5rem; position: relative; overflow: hidden; transition: border-color 0.3s, transform 0.3s; }

.client-card:hover { border-color: var(--green); transform: translateY(-4px); }

.client-card::after { content: ""; position: absolute; top: 0px; left: 0px; right: 0px; height: 3px; background: linear-gradient(90deg, var(--green), var(--gold)); transform: scaleX(0); transform-origin: left center; transition: transform 0.4s; }

.client-card:hover::after { transform: scaleX(1); }

.client-logo-placeholder { width: 60px; height: 60px; background: var(--green-pale); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin-bottom: 1.5rem; font-family: "Playfair Display", serif; font-size: 1.3rem; font-weight: 900; color: var(--green); }

.client-quote { font-family: "Playfair Display", serif; font-size: 1rem; font-style: italic; line-height: 1.7; color: var(--text); margin-bottom: 1.5rem; }

.client-quote::before { content: "“"; color: var(--gold); font-size: 1.5rem; line-height: 0; vertical-align: -0.3em; margin-right: 0.2em; }

.client-quote::after { content: "”"; color: var(--gold); font-size: 1.5rem; line-height: 0; vertical-align: -0.3em; margin-left: 0.2em; }

.client-name { font-size: 0.82rem; font-weight: 600; color: var(--green); letter-spacing: 0.1em; text-transform: uppercase; }

.client-role { font-size: 0.78rem; color: var(--muted); margin-top: 0.2rem; }

.partners-strip { padding: 3rem 4rem 0px; display: flex; align-items: center; gap: 3rem; flex-wrap: wrap; justify-content: center; }

.partner-pill { border: 1px solid rgba(46, 92, 58, 0.15); padding: 0.7rem 2rem; font-size: 0.72rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--muted); font-weight: 500; transition: 0.25s; cursor: default; }

.partner-pill:hover { border-color: var(--green); color: var(--green); }

#actualites { padding: 0px 0px 6rem; background: var(--cream); }

.news-grid { display: grid; grid-template-columns: 2fr 1fr 1fr; gap: 0px; margin: 0px 4rem; border: 1px solid rgba(46, 92, 58, 0.12); }

.news-card { padding: 3rem 2.5rem; border-right: 1px solid rgba(46, 92, 58, 0.1); cursor: pointer; transition: background 0.3s; }

.news-card:last-child { border-right: none; }

.news-card:hover { background: var(--green-pale); }

.news-card.featured { background: var(--dark); }

.news-card.featured:hover { background: rgb(34, 34, 24); }

.news-tag { font-size: 0.62rem; letter-spacing: 0.35em; text-transform: uppercase; color: var(--gold); margin-bottom: 1rem; }

.news-title { font-family: "Playfair Display", serif; font-size: 1.15rem; font-weight: 700; line-height: 1.3; margin-bottom: 0.8rem; }

.news-card.featured .news-title { color: var(--cream); font-size: 1.6rem; }

.news-excerpt { font-size: 0.85rem; line-height: 1.7; color: var(--muted); font-weight: 300; }

.news-card.featured .news-excerpt { color: rgba(244, 240, 230, 0.55); }

.news-date { font-size: 0.72rem; color: rgba(46, 92, 58, 0.5); margin-top: 1.5rem; letter-spacing: 0.15em; }

.news-card.featured .news-date { color: rgba(244, 240, 230, 0.3); }

.news-read { display: inline-flex; align-items: center; gap: 0.5rem; font-size: 0.72rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--gold); margin-top: 1.2rem; text-decoration: none; transition: gap 0.25s; }

.news-read:hover { gap: 0.9rem; }

#contact { background: var(--green); padding: 7rem 4rem; display: grid; grid-template-columns: 1fr 1fr; align-items: center; gap: 4rem; position: relative; overflow: hidden; }

#contact::before { content: ""; position: absolute; width: 700px; height: 700px; border: 100px solid rgba(255, 255, 255, 0.04); border-radius: 50%; top: -200px; right: -200px; }

.contact-left { position: relative; z-index: 1; }

.contact-eyebrow { font-size: 0.68rem; letter-spacing: 0.45em; text-transform: uppercase; color: rgba(200, 168, 75, 0.8); margin-bottom: 1.2rem; }

.contact-title { font-family: "Playfair Display", serif; font-size: clamp(2rem, 3vw, 3rem); font-weight: 900; color: var(--cream); line-height: 1.1; }

.contact-title em { color: var(--gold); font-style: italic; }

.contact-desc { font-size: 0.95rem; line-height: 1.85; color: rgba(244, 240, 230, 0.65); font-weight: 300; max-width: 48ch; margin-top: 1.2rem; }

.contact-right { position: relative; z-index: 1; display: flex; flex-direction: column; gap: 1rem; }

.contact-form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }

.contact-input { background: rgba(244, 240, 230, 0.1); border: 1px solid rgba(244, 240, 230, 0.2); padding: 0.9rem 1.2rem; font-family: "DM Sans", sans-serif; font-size: 0.88rem; color: var(--cream); outline: none; transition: border-color 0.25s; width: 100%; }

.contact-input::placeholder { color: rgba(244, 240, 230, 0.35); }

.contact-input:focus { border-color: var(--gold); }

.contact-textarea { background: rgba(244, 240, 230, 0.1); border: 1px solid rgba(244, 240, 230, 0.2); padding: 0.9rem 1.2rem; font-family: "DM Sans", sans-serif; font-size: 0.88rem; color: var(--cream); resize: none; height: 110px; outline: none; transition: border-color 0.25s; width: 100%; }

.contact-textarea::placeholder { color: rgba(244, 240, 230, 0.35); }

.contact-textarea:focus { border-color: var(--gold); }

footer { background: var(--dark); padding: 4rem; color: rgba(244, 240, 230, 0.5); display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 3rem; border-top: 1px solid rgba(200, 168, 75, 0.15); }

.footer-brand { }

.footer-logo-main { font-family: "Playfair Display", serif; font-size: 1.8rem; font-weight: 900; letter-spacing: 0.12em; text-transform: uppercase; color: var(--cream); margin-bottom: 0.3rem; }

.footer-logo-sub { font-size: 0.6rem; letter-spacing: 0.4em; text-transform: uppercase; color: var(--gold); }

.footer-desc { font-size: 0.85rem; line-height: 1.75; color: rgba(244, 240, 230, 0.4); margin-top: 1.2rem; font-weight: 300; }

.footer-col-title { font-size: 0.68rem; letter-spacing: 0.4em; text-transform: uppercase; color: var(--gold); margin-bottom: 1.2rem; font-weight: 500; }

.footer-links { list-style: none; display: flex; flex-direction: column; gap: 0.6rem; }

.footer-links a { font-size: 0.85rem; color: rgba(244, 240, 230, 0.4); text-decoration: none; transition: color 0.2s; }

.footer-links a:hover { color: var(--cream); }

.footer-bottom { background: var(--dark); padding: 1.5rem 4rem; display: flex; justify-content: space-between; align-items: center; border-top: 1px solid rgba(244, 240, 230, 0.06); }

.footer-bottom p { font-size: 0.72rem; color: rgba(244, 240, 230, 0.25); letter-spacing: 0.1em; }

@keyframes fadeUp { 
  0% { opacity: 0; transform: translateY(28px); }
  100% { opacity: 1; transform: translateY(0px); }
}

.reveal { opacity: 0; transform: translateY(24px); transition: opacity 0.7s, transform 0.7s; }

.reveal.visible { opacity: 1; transform: translateY(0px); }

@media (max-width: 1024px) {
  nav { padding: 0px 2rem; }
  .nav-links { gap: 0px; }
  #accueil, .revaloris-strip, #contact { grid-template-columns: 1fr; }
  .hero-left { padding: 5rem 2rem 3rem; }
  .hero-right { min-height: 380px; }
  .stats-bar { grid-template-columns: repeat(2, 1fr); }
  .services-grid, .clients-grid { grid-template-columns: 1fr; margin: 0px 2rem; }
  .service-card { border-right: none; border-bottom: 1px solid rgba(46, 92, 58, 0.1); }
  .news-grid { grid-template-columns: 1fr; margin: 0px 2rem; }
  .news-card { border-right: none; border-bottom: 1px solid rgba(46, 92, 58, 0.1); }
  footer { grid-template-columns: 1fr 1fr; padding: 3rem 2rem; }
  .footer-bottom { padding: 1.5rem 2rem; flex-direction: column; gap: 0.5rem; }
  #contact { padding: 5rem 2rem; }
  .contact-form-row { grid-template-columns: 1fr; }
  .section-header { padding: 4rem 2rem 2.5rem; }
}

@media (max-width: 640px) {
  .nav-links { display: none; }
  .nav-links.open { display: flex; flex-direction: column; position: absolute; top: 80px; left: 0px; right: 0px; background: var(--cream); padding: 1rem 2rem 2rem; border-bottom: 1px solid rgba(46, 92, 58, 0.15); }
  .burger { display: flex; }
  .stats-bar { grid-template-columns: 1fr 1fr; }
  footer { grid-template-columns: 1fr; }
}
